# HaloClaw Desktop Environment Configuration
# 电商AI助手环境配置

# ===========================================
# Supabase 配置
# ===========================================
SUPABASE_URL=https://kekmppsuiiokdckdeolv.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ===========================================
# NewAPI 配置（计费系统）
# ===========================================
NEW_API_URL=https://your-newapi-instance.com
NEW_API_ADMIN_KEY=your_newapi_admin_key_here
NEW_API_DEFAULT_QUOTA=1000

# ===========================================
# Ozon API 配置
# ===========================================
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
OZON_WAREHOUSE_ID=your_default_warehouse_id

# ===========================================
# 1688 平台配置
# ===========================================
CHINESE_APP_KEY=your_1688_app_key
CHINESE_APP_SECRET=your_1688_app_secret
CHINESE_ACCESS_TOKEN=your_1688_access_token
CHINESE_COOKIES=your_1688_login_cookies_for_playwright

# ===========================================
# AI 模型配置
# ===========================================
DEFAULT_MODEL=claude-3-5-sonnet
FALLBACK_MODEL=gpt-4o
IMAGE_MODEL=gemini-2.0-flash-preview

# ===========================================
# 应用配置
# ===========================================
APP_ENV=development
LOG_LEVEL=info
ENABLE_AUTO_UPDATE=true
